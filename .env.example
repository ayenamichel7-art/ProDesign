# ============================================
# ProDesign – Example Environment Template
# ============================================

# PostgreSQL
POSTGRES_USER=prodesign_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=prodesign_db
DATABASE_URL=postgres://prodesign_user:your_secure_password@db:5432/prodesign_db

# MinIO (Object Storage S3)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_secure_minio_password
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your_secure_minio_password

# Telegram Bot (Automation Robot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Redis
REDIS_URL=redis://redis:6379

# FedaPay (Payments)
FEDAPAY_SECRET=

# Security JWT
JWT_SECRET=

# CORS - Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
